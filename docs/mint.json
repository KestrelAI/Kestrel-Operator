  "footerSocials": {
    "github": "https://github.com/kestrelai",
    "linkedin": "https://www.linkedin.com/company/kestrelhq",
    "x": "https://x.com/kestrel__ai"
  },
  "feedback": {
    "suggestEdit": true,
    "raiseIssue": true,
    "thumbsRating": true
  },
  "modeToggle": {
    "default": "dark",
    "isHidden": false
  },
  "search": {
    "prompt": "Search documentation..."
  },
  "metadata": {
    "og:image": "https://usekestrel.ai/og-image.png",
    "twitter:card": "summary_large_image"
  },
