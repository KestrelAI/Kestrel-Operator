      "destination": "/integrations/aws"
    },
    {
      "source": "/cloud/aws",
      "destination": "/integrations/aws"
    },
    {
      "source": "/cloud/oci",
      "destination": "/integrations/oci"
    },
    {
      "source": "/integrations/cicd",
      "destination": "/integrations/github"
    },
    {
