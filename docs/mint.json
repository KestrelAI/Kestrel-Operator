        "workflows/custom-integrations",
        "workflows/setup-integrations",
        "workflows/observability",
        "workflows/cli",
        "workflows/sdk",
        "workflows/mcp"
      ]
    },
    {
      "group": "Incident Response",
      "pages": [
        "incident-response/kubernetes",
        "incident-response/cloud"
      ]
    },
    {
      "group": "Cloud AI Copilot",
      "pages": [
        "copilot/overview",
        "copilot/kubernetes",
        "copilot/cloud",
        "copilot/code",
        "copilot/costs",
        "copilot/config-changes"
      ]
    },
    {
      "group": "Integrations",
      "pages": [
        "integrations/kubernetes",
        "integrations/aws",
        "integrations/oci",
        "integrations/cloudflare",
        "integrations/slack",
        "integrations/github",
        "integrations/gitlab",
        "integrations/pagerduty",
        "integrations/jira",
        "integrations/confluence",
        "integrations/glean",
        "integrations/linear",
        "integrations/posthog",
        "integrations/vercel",
        "integrations/railway",
        "integrations/flyio",
        "integrations/nebius",
        "integrations/beam",
        "integrations/daytona",
        "integrations/supabase",
        "integrations/planetscale",
        "integrations/neon",
        "integrations/clickhouse",
        "integrations/datadog",
        "integrations/opentelemetry",
        "integrations/argocd",
        "integrations/argo-rollouts",
        "integrations/fluxcd",
        "integrations/karpenter",
        "integrations/helm",
        "integrations/terraform",
        "integrations/pulumi",
        "integrations/jenkins",
        "integrations/circleci",
        "integrations/vault",
        "integrations/infisical",
        "integrations/knowledge-sources"
      ]
    },
    {
      "group": "Enterprise",
      "pages": [
        "enterprise/security",
        "on-premise/overview",
        "on-premise/setup"
      ]
