{
  "$schema": "https://mintlify.com/schema.json",
  "name": "Kestrel AI",
  "logo": {
    "dark": "/logo/dark.svg",
    "light": "/logo/light.svg",
    "href": "https://usekestrel.ai"
  },
  "favicon": "/logo/light.svg",
  "fonts": {
    "heading": {
      "family": "Geist",
      "source": "/fonts/Geist-Variable.woff2",
      "format": "woff2",
      "weight": 400
    },
    "body": {
      "family": "Geist",
      "source": "/fonts/Geist-Variable.woff2",
      "format": "woff2",
      "weight": 400
    }
  },
  "colors": {
    "primary": "#18181B",
    "light": "#FAFAFA",
    "dark": "#18181B",
    "background": {
      "dark": "#09090B",
      "light": "#FFFFFF"
    },
    "anchors": {
      "from": "#52525B",
      "to": "#A1A1AA"
    }
  },
  "topbarLinks": [
    {
      "name": "Support",
      "url": "mailto:hello@usekestrel.ai"
    },
    {
      "name": "GitHub",
      "url": "https://github.com/kestrelai"
    }
  ],
  "topbarCtaButton": {
    "name": "Login",
    "url": "https://platform.usekestrel.ai",
    "style": "roundedRectangle"
  },
  "tabs": [
    {
      "name": "Documentation",
      "url": "/"
    }
  ],
  "anchors": [
    {
      "name": "Blog",
      "icon": "newspaper",
      "url": "https://usekestrel.ai/blog"
    },
    {
      "name": "Changelog",
      "icon": "megaphone",
      "url": "https://usekestrel.ai/changelog"
    }
  ],
  "navigation": [
    {
      "group": "Get Started",
      "pages": [
        "introduction",
        "quickstart/workflows",
        "quickstart/incident-response",
        "quickstart/copilot"
      ]
    },
    {
      "group": "Workflows",
      "pages": [
